{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "framework": null,
  "functions": {
    "artifacts/api-server/api/index.ts": {
      "runtime": "@vercel/node",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/artifacts/api-server/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
