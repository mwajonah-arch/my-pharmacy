{
  "version": 2,
  "builds": [
    {
      "src": "mnt/user-data/outputs/medhub/artifacts/api-server/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { 
      "source": "/api/(.*)", 
      "destination": "mnt/user-data/outputs/medhub/artifacts/api-server/src/index.ts" 
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
