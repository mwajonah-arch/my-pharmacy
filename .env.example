# Neon PostgreSQL — https://neon.tech
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Pusher — https://pusher.com → App Keys
PUSHER_APP_ID="your-app-id"
PUSHER_KEY="your-key"
PUSHER_SECRET="your-secret"
PUSHER_CLUSTER="eu"

# Frontend (safe to expose — embedded in browser bundle by Vite)
VITE_PUSHER_KEY="your-key"
VITE_PUSHER_CLUSTER="eu"

# Your Vercel deployment URL (used for CORS)
FRONTEND_URL="https://medhub.vercel.app"
NODE_ENV="production"
